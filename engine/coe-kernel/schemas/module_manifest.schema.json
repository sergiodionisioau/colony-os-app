{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Module Manifest Schema",
    "type": "object",
    "properties": {
        "name": {
            "type": "string"
        },
        "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "entrypoint": {
            "type": "string",
            "pattern": ".*\\.py$"
        },
        "author": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "dependencies": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "permissions": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "events_subscribed": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "events_emitted": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "capabilities": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "resource_budget": {
            "type": "object",
            "properties": {
                "max_cpu": {
                    "type": "number",
                    "minimum": 0
                },
                "max_memory": {
                    "type": "integer",
                    "minimum": 0
                },
                "max_events_per_minute": {
                    "type": "integer",
                    "minimum": 0
                },
                "max_token_cost": {
                    "type": "number",
                    "minimum": 0
                }
            },
            "required": [
                "max_cpu",
                "max_memory",
                "max_events_per_minute",
                "max_token_cost"
            ]
        },
        "kernel_compatibility": {
            "type": "string"
        }
    },
    "required": [
        "name",
        "version",
        "entrypoint",
        "author",
        "description",
        "permissions",
        "events_subscribed",
        "events_emitted",
        "capabilities",
        "resource_budget"
    ],
    "additionalProperties": true
}